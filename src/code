int PrintCState( string id, int start, string indent ) { // {...}
  if ( gFuncRef[start] != id ) return start;
  int i = start;
  bool state = true;
  int state_begin = i;
  string in = indent;
  bool leave = false;
  bool isIF = false;
  
  if ( gFuncText[i] == "}" ) {
    cout << "}" << endl;
    return i+1;
  } // end if
  
  while ( i < gFuncText.size() && !leave && gFuncText[i] != "}" ) { // 裡面會有while、if 
    if ( gFuncRef[i] != id ) return i;
    cout << indent;
    state = true;
    state_begin = i;
    
    while ( i < gFuncText.size() && !leave && gFuncText[i] != ";" ) { // statement 
      if ( gFuncRef[i] != id ) return i;
      
      if ( gFuncText[i] == "{" ) {
        in += "  ";
        cout << " {" << endl;
        i = PrintCState( id, i+1, in );
        state = false;
      } // end if
       
      if ( gFuncText[i] == "}" ) 
        leave = true;
      else if ( gFuncText[i] == "do" || gFuncText[i] == "else" ) {
        cout << gFuncText[i] << endl << indent << "  " << gFuncText[i+1];
        i++;
      } // end else if
      else if ( isIF && gFuncText[i] == ")" ) {
        cout << " )" << endl << indent << "  " << gFuncText[i+1];
        i++;
      } // end else if
      else if ( gFuncText[i] == "," )
        cout << gFuncText[i];
      else if ( gFuncText[i] == "(" ) {
        if ( gFuncText[i-1] != "if" && gFuncText[i-1] != "while" )
          cout << gFuncText[i];
        else {
          cout << " " << gFuncText[i] ;  
          isIF = true;
        } // end else
      } // end else if
      else if ( gFuncText[i] == "[" )
        cout << gFuncText[i] ;
      else if ( gFuncText[i] == "++" || gFuncText[i] == "--" )
        cout << gFuncText[i] ;
      else {
        if ( !state ) 
          cout << indent << gFuncText[i];
        
        else {
          if ( i != state_begin ) cout << " " << gFuncText[i] ;
          else cout << gFuncText[i];   
        } // end else
        
        state = true;
      } // end else
      
      i++;
    } // end while( ";" )
    
    if ( state ) cout << " ;" << endl;
    i++;
  } // end while( "}" )
  
  if ( indent.length() > 2 ) indent.erase( indent.length() - 2 );
  else indent = "\0";
  
  cout << indent << "}" << endl;
  
  return i+1;
} // end PrintCState()

int PrintFunc( string id, int start, string indent ) { // type FuncName(...)
  if ( gFuncRef[start] != id ) return start;
  int i = start;
  
  // print "type id("
  cout << indent << gFuncText[i] << " " << gFuncText[i+1] << gFuncText[i+2]; 
  i += 3;
  
  // ptint " type ID, type & ID, type ID[ num ] )"
  while ( gFuncText[i] != ")" ) {
    if ( gFuncRef[i] != id ) return i;
    
    if ( gFuncText[i] == "," ) cout << ",";
    else if ( gFuncText[i] == "[" ) cout << "[";
    else if ( gFuncText[i] == "]" ) cout << " ]";
    else cout << " " << gFuncText[i];
