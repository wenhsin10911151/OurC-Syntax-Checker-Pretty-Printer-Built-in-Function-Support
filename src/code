string CheckFirstChar( string str ) {
  int len_lv = glexical_vec.size();
  int len_ov = goperand_vec.size();
  
  for ( int i = 0 ; i < len_lv ; i++ ) {
    if ( str == glexical_vec[i] )
      return "\0";
  } // end for
  
  for ( int i = 0 ; i < len_ov ; i++ ) {
    if ( str == goperand_vec[i] )
      return "\0";
  } // end for
  
  if ( IsIdentifier( gToken ) ) 
    return "\0";
  
  if ( IsConstant( gToken ) ) 
    return "\0";
  else if ( gToken[0] == '\'' ) return "'";
    
  return gToken;
} // end CheckFirstChar()

string Token() { 
  string wrongToken = "\0"; 
  
  GetToken();
  
  while ( gToken == "\n" ) {
    gNumOfLine++;
    GetToken(); 
  } // end while
  
  wrongToken = CheckFirstChar( gToken );
  if ( gNumOfLine == 0 ) gNumOfLine = 1;
    
  if ( wrongToken == "\0" ) {
    gTBuffer.push_back( gToken );
    gTokenLine.push_back( gNumOfLine ); 
    gCur++;
    
    return gToken;
  } // end if
  else {
    cout << "Line " << gNumOfLine << " : unrecognized token with first char : ";
    cout << "'" << wrongToken << "'" << endl;
    gHasUnexpected = true;
    
    return "\0";
  } // end else
} // end Token()

bool CheckDone() {
  if ( gTBuffer[0] == "Done" ) {
    if ( gTBuffer[1] == "(" ) {
      if ( gTBuffer[2] == ")" ) {
        if ( gTBuffer[3] == ";" ) {
          gEXIT = true;
          return true;
        } // end if
      } // end if
    } // end if
  } // end if
  
  return false;
} // end CheckDone()


bool CinCout( string t ) {
  if ( gHasUnexpected ) return false;
  string id = t;
  int line = gNumOfLine;
  
  t = Token();
  while ( t == ">>" || t == "<<" ) { // cin、cout 運算
    t = Token(); // ID 或數字 
    gCoutin = true;
    
    if ( Expression( t ) ) {
      t = gTBuffer[gCur-1];
      if ( t == ";" ) return true;
      else if ( t != "<<" && t != ">>" ) return false;
    } // end if 
    else return false;
  } // end while
  
  if ( CheckDefVar( id, line ) ) { // cin、cout 視為 ID 
    gCoutinID = true;
    if ( Expression( t ) ) return true;
    else return false;
  } // end if
  
  else {  // cin、cout 沒有宣告成 ID  
    UndefId( id, line );
    return false;  
  } // end else
} // end CinCout()

int Parser( string t ) {
    
  if ( gHasUnexpected ) return false;

  if ( t == "[" ) {
    Unexpected_token( "[" );
    return 0;
  } // end if ( "[" )
  
  else if ( Definition( t ) ) {  // Definition & Declaration
    
    return 1;
  } // end else if ( Def )
  else if ( Statement( t ) ) {
    
    return 2;
  } // end else if ( State )
  
  return 0;
} // end Parser()

bool FPList( string t ) { 
  if ( gHasUnexpected ) return false;  
  
  if ( t == ")" ) return true;
  string id = "\0";
  
  while ( IsType( t ) ) {
    t = Token();
      
    if ( t == "&" || ( !IsConstant( t ) && IsIdentifier( t ) ) ) {
      if ( t == "&" ) {
        t = Token();
        if ( !IsIdentifier( t ) ) {
          Unexpected_token( t );
          return false;
        } // end if
        else id = t;
      } // end if (& ID)
      else id = t;
      
      // 這裡的變數要放到大括號vec : gCSDefVar
      gCSDefVar.push_back( id );
      t = Token();
      if ( t == "[" ) {
        t = Token();
        if ( IsConstant( t ) ) {
          t = Token();
          if ( t == "]" ) {
            t = Token();
            if ( t == ")" ) return true;
            else if ( t == "," ) {
              t = Token();
              
