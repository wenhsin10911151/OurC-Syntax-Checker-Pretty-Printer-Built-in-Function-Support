bool Expression( string t ) {
  if ( gHasUnexpected ) return false;
  
  if ( t == "(" ) {
    gParenthesis++;
    t = Token();
    
  } // end if
  else if ( t == "[" ) {
    gSquareBracket++;
    t = Token();  
    
  } // end else if
    
  if ( IsType( t ) || t == "void" ) {
    Unexpected_token( t );
    return false;
  } // end if
  
  if ( BExp( t ) ) return true;
  else return false;
} // end Expression()

bool Statement( string t ) {
  if ( gHasUnexpected ) return false;  
  
  if ( t == ";" ) {
    return true;
  } // end if ( ";" )
  else if ( t == "return" ) {
    t = Token();
    if ( Expression( t ) ) {
      return true; 
    } // end if ( exp )
    
    return false;
  } // end if ( "return" )
  
  else if ( t == "cout" || t == "cin" ) {
    if ( CinCout( t ) ) return true;
    return false;  
  } // end else if
  
  else if ( t == "{" ) {
    if ( CState( t ) ) {
      return true;
    } // end if ( CState )
    
    return false;   
  } // end if ( "{" )
  
  else if ( t == "(" ) {
    if ( Expression( t ) ) {
      t = Token();
      if ( t == ";" ) return true;
      else {
        Unexpected_token( t );
        return false; 
      } // end else
    } // end if
    
    return false;
  } // end else if
  
  else if ( t == "if" ) {
    // if '(' expression ')' statement [ ELSE statement ] 
    t = Token();
    if ( t == "(" ) {
      gIF = true;
      if ( Expression( t ) ) {
        gIF = false;
        
        t = Token();
        if ( Statement( t ) ) {
          t = Token();
          
          if ( gCState && t == "}" ) {
            gIF = true;
            return true;  
          } // end if
          else if ( t == "else" ) {
            t = Token();
            if ( Statement( t ) ) return true;
            else return false;
          } // end if ( "else" )
          
          // else if ( Statement( t ) ) return true;
          else {
            gTtoken = t;
            return true;  
          } // end else
        } // end if ( state )
      } // end if ( exp )
    } // end if ( "(" )
    else Unexpected_token( t );
    
    return false;
  } // end else if ( "if" )
  
  else if ( t == "while" ) {
    // WHILE '(' expression ')' statement
    t = Token();
    if ( t == "(" ) {
      gIF = true;
      if ( Expression( t ) ) {
        gIF = false;
        t = Token();
        
        if ( Statement( t ) ) {
          return true;
        } // end if ( state ) 
        else return false;
      } // end if ( exp )  
    } // end if ( "(" )
    else Unexpected_token( t );
    
    return false;
  } // end else if ( "while" )
  
  else if ( t == "do" ) {
    // DO statement WHILE '(' expression ')' ';' 
    t = Token();
    gDO = true;
    if ( Statement( t ) ) {
      t = Token();
      if ( t == "while" ) {
        t = Token();
        if ( t == "(" ) {
          if ( Expression( t ) ) {
            t = gTBuffer[gCur-1] ;
            t = Token();
            
            if ( t == ";" ) return true;  
            else Unexpected_token( t );
          } // end if ( Expression )
        } // end if ( "(" )
        else Unexpected_token( t );
      } // end if ( "while" )
      else Unexpected_token( t );
    } // end if ( state )
    
    return false;
  } // end else if ( "do" )
  
  else if ( Expression( t ) ) {
    return true;
  } // end else if ( Expression )
  
  return false;
} // end Statement()

bool IsConstant( string str ) {
  if ( IsNum( str ) || str == "true" || str == "false" ) 
    return true;
  
  if ( str[0] == '"' && str[str.length()-1] == '"' ) 
    return true;
    
  if ( str[0] == '\'' ) {
    if ( str.size() == 3 ) return true;
  } // end if
  
  return false;
} // end IsConstant()

bool IsLexical_vec( string str ) {
  int len_lex = glexical_vec.size(); 
  for ( int i = 0 ; i < len_lex ; i++ ) 
    if ( glexical_vec[i] == str ) return true;
    
  return false;
} // end IsLexical_vec()

bool IsIdentifier( string str ) {
  if ( IsLexical_vec( str ) ) return false;
  
  if ( !IsLetter( str[0] ) )
    return false;
  else {
    int i = 1;
    while ( i < str.size() ) {
      if ( !IsDigit( str[i] ) && !IsLetter( str[i] ) && str[i] != '_' )
        return false;
      else
        i++;
        
    } // end while
    
    return true;
  } // end else
} // end IsIdentifier()

bool IsInt( string str ) {
  int i = 0; 
  while ( i < str.size() ) {
    if ( !IsDigit( str[i] ) ) return false;
    else i++;
  } // end while
  
  return true;
} // end IsInt()

bool IsNum( string str ) {
  int len = str.size();
  bool findDot = false;
  for ( int i = 0 ; i < len ; i++ ) {
    if ( str[i] == '.' ) findDot = true;
    else if ( !IsDigit( str[i] ) ) return false;
    
  } // end for

  return true;
} // end IsNum()

bool IsDigit( char ch ) {
  if ( 48 <= ch && ch <= 57 ) return true;
  else return false;
  
} // end IsDigit()

bool IsLetter( char ch ) {
  if ( ( 65 <= ch && ch <= 90 ) || ( 97 <= ch && ch <= 122 ) ) 
    return true;
  else 
    return false;
  
} // end IsLetter()

bool IsOparend( string str ) {
  int len_ov = goperand_vec.size();  
  for ( int i = 0 ; i < len_ov ; i++ ) {
    if ( str == goperand_vec[i] )
      return true;
  } // end for
  
  return false;
} // end IsOparend()

bool IsType( string str ) { 
  //  INT | CHAR | FLOAT | STRING | BOOL 
  for ( int i = 0 ; i < 5 ; i++ ) {
    if ( glexical_vec[i] == str ) return true;
  } // end for
  
  return false;
} // end IsType()

bool IsGrant( string t ) { // 給予值(有等號的) 
  if ( t == "=" ) return true;
  for ( int i = 24 ; i < 29 ; i++ ) {
    if ( t == goperand_vec[i] ) return true;
  } // end for
  
  return false;
} // end IsGrant() 

bool IsPPMM( string t ) {
  if ( t == "++" || t == "--" ) return true;
  else return false;
} // end IsPPMM()

bool IsArithOP( string t ) {
  for ( int i = 6 ; i < 12 ; i++ ) {
    if ( t == goperand_vec[i] ) return true;
  } // end for
  
  return false;
} // end IsArithOP()

bool IsLogicalOP( string t ) {
  if ( t == "&&" || t == "||" )
    return true;  
    
  for ( int i = 12 ; i < 20 ; i++ ) {
    if ( t == goperand_vec[i] ) return true;
  } // end for
  
  return false;
} // end IsLogicalOP()

bool IsSign( string t ) {
  if ( t == "+" || t == "-" || t == "!" ) return true;
  else return false;
} // end IsSign()

bool IsShiftOP( string t ) {
  if ( t == "<<" || t == ">>" ) return true;
  else return false;  
} // end IsShiftOP()

bool IsAllCalOP( string t ) { // Calculate Op
  if ( IsShiftOP( t ) || IsLogicalOP( t ) || IsArithOP( t ) )
    return true; 
  else 
    return false;
} // end IsAllCalOP()

void GetToken() {
  string token = "\0";
  char inputChar = '\0';
  bool findToken = false;
  bool findDot = false;
  
  while ( !findToken ) {
    
    // has NextToken
    if ( gNextToken != "\0" ) {
      gToken = gNextToken;
      gNextToken = "\0";
      findToken = true;
      
    } // end if
    else {
      // get char
      if ( gExtraGetChar != '\0' ) {
        inputChar = gExtraGetChar;
        gExtraGetChar = '\0';
      } // end if
      else inputChar = cin.get();
      
      
      // white space
      if ( inputChar == ' ' || inputChar == '\t' || inputChar == '\n' ) {  
        char tmp = inputChar;
        
        if ( token != "\0" ) {
          gToken = token;
          token = "\0";
          findToken = true;
          inputChar = '\0';
            
        } // end if  
        
        if ( tmp == '\n' ) {
          if ( findToken ) gNextToken = "\n";
          else gToken = "\n";
          
          findToken = true;
          
        } // end if
        
        // continue;
      } // end if (white space)
        
      // comment & div & /=
      else if ( inputChar == '/' ) {
        inputChar = cin.get(); // get next char
        
        // comment
        if ( inputChar == '/' ) {
          if ( token != "\0" ) {
            gToken = token;
            token = "\0";
            findToken = true;
            inputChar = '\0';
            
          } // end if
          
          while ( inputChar != '\n' ) {
            
            inputChar = cin.get();  
          } // end while
          
          if ( findToken ) gNextToken = "\n";
          else {
            gToken = "\n";
            token = "\0";
            findToken = true;
            inputChar = '\0';
          } // end else
          
          inputChar = '\0';
          
        } // end if (comment)
        
        else if ( inputChar == '=' ) {
          if ( token != "\0" ) {
            gToken = token;
            token = "\0";
            findToken = true;
            inputChar = '\0';
            
          } // end if
          
          if ( findToken ) gNextToken = "/=";
          else gToken = "/=";
            
          token = "\0";
          findToken = true;
          inputChar = '\0';
            
        } // end else if
        
        // div
        else {
          gExtraGetChar = inputChar;
          if ( token != "\0" ) {
            gToken = token;
            gNextToken = "/";
            findToken = true;
            
          } // end if
          else {
            gToken = "/";
            findToken = true;
          } // end else
        } // end else(div)
      } // end else if (comment & div & /= )
      
      // STRING
      else if ( inputChar == '"' ) {
        if ( token != "\0" ) {
          gToken = token;
          findToken = true;
          gExtraGetChar = '"';
          inputChar = '\0';
        } // end if 
        else {
          // gNextToken = "\"";
          token = '"';
          inputChar = cin.get(); 
          bool out = false;
          while ( inputChar != '"' && !out ) {
            if ( inputChar == '\n' ) {  // inputChar == ';' || 
              if ( token != "\0" ) {
                gToken = token;
                findToken = true;
              } // end if
              
              if ( findToken ) gNextToken = "\n";
              else gToken = "\n";
              
              inputChar = '\0';
              // cout << "Syntax error: string missing terminating '\"'." << endl;
              out = true;  
            
            } // end if
            else {
              // gNextToken += inputChar ;
              token += inputChar;
              inputChar = cin.get();  
            } // end else
          } // end while
          
          if ( findToken ) {
            gExtraGetChar = inputChar;
          } // end if
          else {
            if ( inputChar == '"' ) {
              // gNextToken += inputChar ;
              token += inputChar ; 
              gToken = token;
              findToken = true;
              inputChar = '\0';
              
            } // end if
            else {
              if ( token != "\0" ) {
                gToken = token;
                findToken = true;
              } // end if
              
              if ( findToken ) gNextToken = inputChar;
              else gToken = inputChar;
            
              // gNextToken = "\0";
            } // end else  
          } // end else
        } // end else
      } // end else if ( "..." )
        
      // char
      else if ( inputChar == '\'' ) {      
        if ( token != "\0" ) {
          gToken = token;
          findToken = true;
          
        } // end if 
      
        inputChar = cin.get();
        gNextToken = "'";
        bool outwhile = false;
        while ( inputChar != '\'' && !outwhile ) {
          if ( inputChar == ';' || inputChar == '\n' ) {
            outwhile = true;
          } // end if
          else {
            gNextToken += inputChar ;
            inputChar = cin.get();  
          } // end else
        } // end while
        
        if ( inputChar == '\'' ) {
          gNextToken += inputChar ; 
          inputChar = '\0'; 
        } // end if
        else {
          gExtraGetChar = inputChar;
          inputChar = '\0';
        } // end else
          
      } // end else if ('c')
        
      else {
        char tempChar = '\0';
        string tempStr = "\0";
        tempChar = inputChar;
        tempStr = inputChar;
        
        if ( tempChar == '=' || tempChar == '&' || tempChar == '|' ) {
          inputChar = cin.get();
        
          if ( token != "\0" ) {
            gToken = token;
            token = "\0";
            findToken = true;
            
          } // end if
        
          if ( inputChar == tempChar ) {
            if ( findToken ) gNextToken = tempStr+inputChar;
            else gToken = tempStr+inputChar;
            
            token = "\0";
            findToken = true;
            inputChar = '\0';
          } // end if
          else {
            if ( findToken ) gNextToken = tempStr;
            else gToken = tempStr;
            
            token = "\0";
            findToken = true;
            gExtraGetChar = inputChar;
            inputChar = '\0';
            
          } // end else
        } // end if
      
        else if ( tempChar == '*' || tempChar == '%' || tempChar == '!' ) {
          inputChar = cin.get();
          if ( token != "\0" ) {
            gToken = token;
            token = "\0";
            findToken = true;
             
          } // end if
        
          if ( inputChar == '=' ) {
            if ( findToken ) gNextToken = tempStr+inputChar;
            else gToken = tempStr+inputChar;
            
            token = "\0";
            findToken = true;
            inputChar = '\0';
          } // end if
          else {
            if ( findToken ) gNextToken = tempStr;
            else gToken = tempStr;
            
            token = "\0";
            findToken = true;
            gExtraGetChar = inputChar;
            inputChar = '\0';
            
          } // end else
        } // end else if
        
        else if ( tempChar == '<' || tempChar == '>'  || tempChar == '+' || tempChar == '-' ) {
          inputChar = cin.get();
            
          if ( token != "\0" ) {
            gToken = token;
            token = "\0";
            findToken = true;
          
          } // end if
          
          if ( inputChar == '=' ) {
            if ( findToken ) gNextToken = tempStr+inputChar; 
            else gToken = tempStr+inputChar;
            
            token = "\0";
            findToken = true;
            inputChar = '\0';
          } // end if
          else if ( inputChar == tempChar ) {
            if ( findToken ) gNextToken = tempStr+inputChar;
            else gToken = tempStr+inputChar;
            
            token = "\0";
            findToken = true;
            inputChar = '\0';
          } // end else if
          else {
            if ( findToken ) gNextToken = tempStr; 
            else gToken = tempStr;
            
            token = "\0";
            findToken = true;
            gExtraGetChar = inputChar;
            inputChar = '\0';
            
          } // end else
        } // end if
        
        else if ( IsDigit( tempChar ) || IsLetter( tempChar ) || tempChar == '.' ||  tempChar == '_' ) {
          bool ctu = false;
          if ( findDot && tempChar == '.' ) {
            gToken = token;
            token = "\0";
            findToken = true;
            gExtraGetChar = tempChar;
            ctu = true; // continue;
          } // end if
          else if ( tempChar == '.' ) findDot = true;
          
          if ( !ctu ) {
            if ( token == "\0" ) token = tempChar; 
            else token += tempChar;  
          } // end if
        } // end else if
      
        else {
          if ( token != "\0" ) {
            gToken = token;
            token = "\0";
            findToken = true;
            
          } // end if
            
          if ( findToken ) gNextToken = tempStr;
          else gToken = tempStr;
          
          token = "\0";
          findToken = true;
          inputChar = '\0';
            
        } // end else
      } // end else
    } // end else
  } // end while
} // end GetToken()
