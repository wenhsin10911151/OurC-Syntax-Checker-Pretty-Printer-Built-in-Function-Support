void UpdateNewDefVar( string id, string type ) {
  for ( int k = 0 ; k < gDefVar.size() ; k++ ) {
    if ( gDefVar[k] == id ) {
      
      gDefVar.erase( gDefVar.begin() + k );
      gVarType.erase( gVarType.begin() + k );
      
      if ( gDefVar[k] == "[" ) {
          
        while ( gDefVar[k] != "]" ) {
          gDefVar.erase( gDefVar.begin() + k );
          gVarType.erase( gVarType.begin() + k );
        } // end while
        
