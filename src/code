void StoreDefVar() {
  int numOfToken = gTBuffer.size();
  string type = "\0";
  int i = 0; // index
  
  while ( i < numOfToken ) {
    
    if ( i == 0 ) {
      if ( IsType( gTBuffer[i] ) ) type = gTBuffer[i];
      else cout << "Can't find type." << endl;
      
    } // end if
    else if ( gTBuffer[i] != ";" && gTBuffer[i] != "," ) {
        
      if ( gTBuffer[i] == "[" ) { // 變數 [ 陣列 ] 
        while ( gTBuffer[i] != "]" ) {
          gDefVar.push_back( gTBuffer[i] );
          gVarType.push_back( type );
          i++;
          
        } // end while
        
        gDefVar.push_back( gTBuffer[i] );
        gVarType.push_back( type );
      } // end if
      else {
        if ( CheckDefVar( gTBuffer[i], gTokenLine[i] ) ) {
          UpdateNewDefVar( gTBuffer[i], type ); // 要改gDefVar、 gVarType
          cout << "New definition of " << gTBuffer[i] << " entered ..." << endl;
        } // end if
        else {
          gDefVar.push_back( gTBuffer[i] );
          gVarType.push_back( type );
          cout << "Definition of " << gTBuffer[i] << " entered ..." << endl;  
        } // end else  
      } // end else
    } // end else if
      
    i++;
  } // end while
} // end StoreDefVar()

