void UpdateNewDefFunc( string id ) {
  int lenOfDefFunc = gDefFunc.size();
  
  for ( int i = 0 ; i < lenOfDefFunc ; i++ ) {
    if ( gDefFunc[i] == id ) {
      gDefFunc.erase( gDefFunc.begin() + i );
      i = lenOfDefFunc;
    } // end if
  } // end for
  
  for ( int j = 0 ; j < gFuncRef.size() ; j++ ) {
    while ( j < gFuncRef.size() && gFuncRef[j] == id ) {
      gFuncRef.erase( gFuncRef.begin() + j );
      gFuncText.erase( gFuncText.begin() + j );
      
    } // end while
  } // end for
} // UpdateNewDefFunc()

