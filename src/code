void StoreDeclareVar( int start ) { 
  // 大括號裡面的 Declare
  int i = start;
  int len = gTBuffer.size();  
  // 因為 gTBuffer 裡面存的是 這一次全部輸入 
  while ( i < len ) {  
    if ( IsType( gTBuffer[i] ) ) {
      i++;
      while ( gTBuffer[i] != ";" ) {
        
        if ( gTBuffer[i] != "," )
          gCSDefVar.push_back( gTBuffer[i] );
          
        i++;
      } // end while
    } // end if
    else i = len;
    
    i++;
  } // end while
} // end StoreDeclareVar()

bool CState( string t ) {
  if ( gHasUnexpected ) return false;  
  
  // '{' { declaration | statement } '}' 
  int start = gTBuffer.size();
  bool contiu = true;
  
  if ( t == "{" ) {
    t = Token(); 
    if ( t == "}" ) return true;
    gCState = true;
    
    while ( contiu ) { // Declaration( t ) || Statement( t ) ) {
      if ( IsType( t ) ) {
        if ( Declaration( t ) ) contiu = true;
        else contiu = false;
      } // end if
      else if ( Statement( t ) ) contiu = true;
      else contiu = false;
      
      if ( contiu ) {
        StoreDeclareVar( start );
        start = gTBuffer.size();

        if ( gIF ) {
          t = gTBuffer[gCur-1];
          gIF = false; 
        } // end if
        else if ( gTtoken != "\0" ) {
          t = gTtoken;
          gTtoken = "\0";
        } // end else if
        else t = Token();
        
        if ( t == "}" ) {
          // gCState = false;
          return true;
        } // end if
      } // end if
    } // end while
  } // end if
  
  return false;
} // end CState()

bool Unary_exp( string t ) {
  if ( gHasUnexpected ) return false;  
  
  bool sign = false;
  bool pm = false;
  
  if ( IsPPMM( t ) ) {
    pm = true;
    t = Token();
  } // end if ( PPMM )
  else if ( IsSign( t ) ) {
    sign = true;
    t = Token();
    while ( IsSign( t ) ) {
      t = Token();
    } // end while
  } // end else if ( SIGN )
  
  if ( !IsConstant( t ) && IsIdentifier( t ) ) {
    string id = t;
    int line = gNumOfLine;
    
    if ( !CheckDefVar( id, line ) && !CheckDefFunc( id, line ) ) {
      UndefId( id, line );
      return false;
    } // end if
    
    t = Token();
    
    if ( t == "(" && !pm ) { // ( actual_parameter_list )
      if ( !CheckDefFunc( id, line ) ) {
        UndefId( id, line );
        return false;
      } // end if
      else if ( APList( t ) ) {
        t = Token();  
        return true;   
      } // end else if
      else return false;
    } // end if
    
    if ( t == "[" ) { // [ expression ]
      if ( Expression( t ) ) {
        t = gTBuffer[gCur-1];
        
        if ( t == "]" ) {
          t = Token();
          return true;
        } // end if
        else Unexpected_token( t );
      } // end if ( exp )
      
      return false;
    } // end if ( "[" )
    
    else if ( IsPPMM( t ) && !pm ) { // ID PPMM
      t = Token();
      return true;
    } // end else if
    else return true;
  } // end if ( Identifier )
  
  else if ( !pm && IsConstant( t ) ) { // Constant
    t = Token();
    return true;
  } // end else if ( Constant )
  
  else if ( !pm && t == "(" ) { // ( expression ) 
    if ( Expression( t ) ) {
      t = gTBuffer[gCur-1];
      
      if ( t == ")" ) {
        t = Token();
        return true;  
      } // end if
      // else if ( t == ";" ) return true;
      else Unexpected_token( t );
    } // end if ( exp ) 
    
    return false;
  } // end else if ( "(" )
  else Unexpected_token( t );
  
  return false;
} // end Unary_exp()

bool RomceAndRomloe( string t ) {
  if ( gHasUnexpected ) return false;  
  
  if ( t == "]" ) {
    if ( gSquareBracket == 0 ) {
      Unexpected_token( "]" );
      return false;
    } // end if
    else {
      gSquareBracket--;
      return true; 
    } // end else
  } // end if
  else if ( t == ")" ) {
    
    if ( gParenthesis == 0 ) {
      Unexpected_token( t );
      return false;
    } // end if
    else {
      gParenthesis--;
      return true;
    } // end else 
  } // end else if
    
  if ( IsAllCalOP( t ) ) {
    t = Token();
    
    if ( Unary_exp( t ) ) { 
      t = gTBuffer[gCur-1]; // Unary_exp裡會多讀 Token 
      
      if ( RomceAndRomloe( t ) ) return true;
      else return false;
    } // end if ( Unary_exp )
  } // end if
  else {
    if ( t == "," ) {
      if ( gAPList ) {
        t = Token();
        if ( BExp( t ) ) return true;  
        else return false;  
      } // end if (gAPList)
      else {
        Unexpected_token( t );  
        return false;
      } // end else
    } // end if ( "," )
    
    if ( t == ";" ) {
      if ( gSquareBracket == 0 && gParenthesis == 0 ) return true;  
      else {
        if ( gSquareBracket > 0 )
          Unexpected_token( t );  
        else if ( gParenthesis > 0 ) {
          Unexpected_token( t );
        } // end else if
          
        return false;
      } // end else 
    } // end if
    
    if ( t == "?" ) {
      gRAR = true;
      t = Token();
      if ( BExp( t ) ) {
        t = gTBuffer[gCur-1];
        if ( t == ":" ) {
          t = Token();
          if ( BExp( t ) ) {
            t = gTBuffer[gCur-1];
            if ( t == ";" ) return true;
            else Unexpected_token( t );
          } // end if (BExp)
        } // end if ( ":" )
        else Unexpected_token( t ); 
      } // end if (BExp)
    } // end if ( "?" )
    else if ( t == ":" ) {
      if ( gRAR ) {
        gRAR = false;
        return true;  
      } // end if
      else {
        Unexpected_token( t ); 
        return false; 
      } // end else
    } // end else if
    else Unexpected_token( t );
  } // end else
  
  return false;
} // end RomceAndRomloe()

